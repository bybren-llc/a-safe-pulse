{
  "name": "a-safe-pulse",
  "version": "0.1.0",
  "description": "A SAFe Pulse — Linear Planning Agent for SAFe workflow integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.prod.json",
    "build:dev": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "test": "jest",
    "test:watch": "jest --watch",
    "cli": "ts-node src/cli/index.ts",
    "cli:build": "tsc && chmod +x dist/cli/index.js",
    "parse": "ts-node src/cli/index.ts parse",
    "create": "ts-node src/cli/index.ts create",
    "sync:start": "ts-node src/cli/index.ts sync start",
    "sync:stop": "ts-node src/cli/index.ts sync stop",
    "sync:status": "ts-node src/cli/index.ts sync status",
    "sync:trigger": "ts-node src/cli/index.ts sync trigger",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByBren-LLC/A-SAFe-Pulse.git"
  },
  "keywords": [
    "linear",
    "agent",
    "safe",
    "planning",
    "a-safe-pulse"
  ],
  "author": "ByBren, LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ByBren-LLC/A-SAFe-Pulse/issues"
  },
  "homepage": "https://github.com/ByBren-LLC/A-SAFe-Pulse#readme",
  "dependencies": {
    "@linear/sdk": "^2.6.0",
    "@types/express-session": "^1.18.1",
    "axios": "^1.9.0",
    "cheerio": "^1.0.0",
    "commander": "^11.1.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.1",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^4.17.22",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^18.19.101",
    "@types/pg": "^8.6.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  }
}
