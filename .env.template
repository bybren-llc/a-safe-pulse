# Linear OAuth Application Credentials
LINEAR_CLIENT_ID=your_linear_client_id
LINEAR_CLIENT_SECRET=your_linear_client_secret
LINEAR_REDIRECT_URI=http://localhost:3000/auth/callback

# Linear Organization and Team IDs (Retrieved from Linear API)
LINEAR_ORGANIZATION_ID=your_linear_organization_id
LINEAR_TEAM_ID=your_linear_team_id

# Linear Team Information
LINEAR_TEAM_KEY=LIN
LINEAR_TEAM_NAME=Linear agents

# Additional Linear Teams
LINEAR_TEAM_REN_ID=your_ren_team_id
LINEAR_TEAM_REN_KEY=REN
LINEAR_TEAM_REN_NAME=RenderTrust Team

LINEAR_TEAM_WOR_ID=your_wor_team_id
LINEAR_TEAM_WOR_KEY=WOR
LINEAR_TEAM_WOR_NAME=WTFB app team

# Common Linear Label IDs
LINEAR_LABEL_BUG=your_bug_label_id
LINEAR_LABEL_FEATURE=your_feature_label_id
LINEAR_LABEL_IMPROVEMENT=your_improvement_label_id
LINEAR_LABEL_ERROR_HANDLING=your_error_handling_label_id
LINEAR_LABEL_TECHNICAL_ENABLER=your_technical_enabler_label_id
LINEAR_LABEL_AUGGIE=your_auggie_label_id

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret

# Database Connection Docker container (app running in Docker)
DATABASE_URL=postgresql://postgres:postgres@db:5432/linear_agent

# Security
ENCRYPTION_KEY=generate_a_strong_random_key_at_least_32_chars

# Server Configuration
PORT=3000
NODE_ENV=development

# SQLite Configuration
SQLITE_DB_PATH=./data/sync.db

# Confluence OAuth Application Credentials (Required for Docker)
CONFLUENCE_CLIENT_ID=your_confluence_client_id
CONFLUENCE_CLIENT_SECRET=your_confluence_client_secret

# Confluence API Credentials (Legacy - for CLI outside Docker)
CONFLUENCE_USERNAME=your_confluence_username
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki

# Application Configuration (Required for OAuth)
APP_URL=http://localhost:3000
SESSION_SECRET=generate_32_character_random_string

# Slack Integration (SAFe Pulse App)
# Primary integration uses incoming webhooks for notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Slack App Credentials (SAFe Pulse App - for interactive features)
# Note: Current implementation uses webhook notifications only
# These credentials enable future slash commands and interactive components
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_APP_TOKEN=your_slack_app_level_token

# Optional: Channel overrides for different notification types
SLACK_PLANNING_CHANNEL=#planning-ops
SLACK_ALERTS_CHANNEL=#system-alerts
SLACK_SYNC_CHANNEL=#sync-status
SLACK_WORKFLOW_CHANNEL=#dev-workflow
SLACK_ERRORS_CHANNEL=#critical-alerts
SLACK_AGENT_CHANNEL=#agent-updates

# https://linear.app/developers/agents
# https://github.com/ByBren-LLC/A-SAFe-Pulse
